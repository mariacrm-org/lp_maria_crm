---
// src/components/Hero.astro
interface Pill {
  label: string;
  icon: string;
}

interface Cta {
  label: string;
  url: string;
}

interface Props {
  badgeText: string;
  titleHtml: string;
  description: string;
  pills: Pill[];
  primaryCta: Cta;
  secondaryCta: Cta;
}

const { badgeText, titleHtml, description, pills, primaryCta, secondaryCta } = Astro.props;
---
<section class="pt-[10rem] pb-24 text-center bg-[radial-gradient(circle_at_top_center,rgba(139,46,252,0.05)_0%,transparent_60%)] max-w-[1440px] mx-auto px-6">
    <div class="inline-flex items-center gap-2 bg-[#dcfce7] text-[#16a34a] border border-[#bbf7d0] px-4 py-[0.4rem] rounded-full text-[0.88rem] font-bold mb-8">
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        {badgeText}
    </div>

    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6 max-w-[900px] mx-auto text-text-dark leading-[1.1] [&_span]:text-primary" set:html={titleHtml} />
    <p class="text-lg md:text-xl text-text-body max-w-[650px] mx-auto mb-10 leading-[1.7]">{description}</p>

    <div class="flex justify-center gap-3 flex-wrap mb-14">
        {pills.map((pill) => (
            <span class="bg-white text-primary px-5 py-2 rounded-full text-[14.5px] font-bold inline-flex items-center gap-2 border border-border-color shadow-sm">
                <span class="material-symbols-outlined text-[1.15rem]">{pill.icon}</span> {pill.label}
            </span>
        ))}
    </div>

    <div class="flex gap-4 justify-center items-center">
        <a href={primaryCta.url} class="bg-primary text-white px-7 py-3 rounded-lg no-underline font-semibold text-[15px] inline-flex items-center gap-2 border-none cursor-pointer transition-all duration-200 shadow-[0_4px_14px_0_rgba(139,46,252,0.3)] hover:bg-primary-hover hover:-translate-y-[2px] hover:shadow-[0_6px_20px_rgba(139,46,252,0.2)]" id="hero-cta-planos">
            {primaryCta.label}
        </a>
        <a href={secondaryCta.url} target="_blank" class="bg-primary-light text-primary px-7 py-3 rounded-lg no-underline font-semibold text-[15px] transition-all duration-200 inline-flex items-center justify-center gap-2 hover:bg-[#e9d5ff]" id="hero-cta-wpp">
            {secondaryCta.label}
        </a>
    </div>
</section>
