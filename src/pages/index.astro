---
// src/pages/index.astro
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import ComoFunciona from '../components/ComoFunciona.astro';
import RecursosWhatsApp from '../components/RecursosWhatsApp.astro';
import RecursosPipeline from '../components/RecursosPipeline.astro';
import RecursosDashboard from '../components/RecursosDashboard.astro';
import Pricing from '../components/Pricing.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

// Simulação de resposta de API com todos os dados da página
import landingData from '../data/landing-data.json';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MariaCRM | Gerencie Grupos de WhatsApp e Acelere suas Vendas</title>
    <!-- Google Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <meta name="description" content="O CRM que se conecta diretamente ao WhatsApp. Gerencie grupos, importe leads automaticamente e feche mais negócios. Planos a partir de R$100/mês.">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet">
    <style is:global>
        body {
            font-family: 'Inter', sans-serif;
            color: #4b5563;
            background-color: #ffffff;
            margin: 0;
            padding: 0;
        }
    </style>
</head>
<body class="bg-white font-sans text-text-body">

    <!-- WhatsApp Float -->
    <a href="https://wa.me/557734212083" target="_blank" class="fixed bottom-8 right-8 bg-[#25D366] text-white w-[60px] h-[60px] rounded-full flex items-center justify-center shadow-[0_8px_25px_rgba(37,211,102,0.4)] no-underline z-[100] transition-all duration-200 hover:scale-110 hover:shadow-[0_12px_30px_rgba(37,211,102,0.5)]" id="wpp-float-btn" title="Fale no WhatsApp">
        <svg viewBox="0 0 24 24" class="w-[30px] h-[30px]" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
    </a>

    <!-- Header -->
    <Header 
        companyName={landingData.company.name} 
        links={landingData.header.links} 
        ctaText={landingData.header.ctaText} 
        whatsappUrl={landingData.company.whatsappUrl} 
    />

    <main>
        <!-- Hero Section -->
        <Hero 
            badgeText={landingData.hero.badgeText}
            titleHtml={landingData.hero.titleHtml}
            description={landingData.hero.description}
            pills={landingData.hero.pills}
            primaryCta={landingData.hero.primaryCta}
            secondaryCta={landingData.hero.secondaryCta}
        />

        <!-- Stats Bar -->
        <StatsBar stats={landingData.stats} />

        <!-- Como Funciona -->
        <ComoFunciona 
            title={landingData.howItWorks.title}
            description={landingData.howItWorks.description}
            steps={landingData.howItWorks.steps}
        />

        <!-- Recursos: WhatsApp + Funis -->
        <RecursosWhatsApp 
            badgeText={landingData.features.whatsapp.badgeText}
            badgeIcon={landingData.features.whatsapp.badgeIcon}
            title={landingData.features.whatsapp.title}
            description={landingData.features.whatsapp.description}
            accordions={landingData.features.whatsapp.accordions}
        />

        <!-- Recursos: Funis e Pipeline -->
        <RecursosPipeline 
            badgeText={landingData.features.pipeline.badgeText}
            badgeIcon={landingData.features.pipeline.badgeIcon}
            title={landingData.features.pipeline.title}
            description={landingData.features.pipeline.description}
            accordions={landingData.features.pipeline.accordions}
        />

        <!-- Recursos: Contatos e Dashboard -->
        <RecursosDashboard 
            badgeText={landingData.features.dashboard.badgeText}
            badgeIcon={landingData.features.dashboard.badgeIcon}
            title={landingData.features.dashboard.title}
            description={landingData.features.dashboard.description}
            accordions={landingData.features.dashboard.accordions}
        />

        <!-- Pricing -->
        <Pricing 
            title={landingData.pricing.title}
            description={landingData.pricing.description}
            plans={landingData.pricing.plans}
        />

        <!-- Call To Action -->
        <CTA 
            title={landingData.cta.title}
            description={landingData.cta.description}
            primaryCta={landingData.cta.primaryCta}
            secondaryCta={landingData.cta.secondaryCta}
        />

    </main>

    <!-- Footer -->
    <Footer 
        description={landingData.footer.description}
        contactLabel={landingData.footer.contactLabel}
        whatsappNumber={landingData.company.whatsappNumber}
        whatsappUrl={landingData.company.whatsappUrl}
        copyright={landingData.footer.copyright}
    />

</body>
</html>
