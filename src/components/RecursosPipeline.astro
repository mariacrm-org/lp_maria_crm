---
// src/components/RecursosPipeline.astro
interface AccordionItem {
  title: string;
  content: string;
}

interface Props {
  badgeText: string;
  badgeIcon: string;
  title: string;
  description: string;
  accordions: AccordionItem[];
}

const { badgeText, badgeIcon, title, description, accordions } = Astro.props;
---
<section class="py-24 border-t border-border-color max-w-[1440px] mx-auto px-6 bg-bg-app">
    <div class="flex flex-col lg:flex-row-reverse items-center gap-12 lg:gap-20">
        <div class="w-full lg:w-1/2">
            <span class="text-primary font-bold text-[0.85rem] uppercase tracking-wider mb-4 inline-flex items-center gap-1.5 bg-primary-light px-3.5 py-1.5 rounded-full">
                <span class="material-symbols-outlined text-[1.1rem]">{badgeIcon}</span> {badgeText}
            </span>
            <h2 class="text-3xl md:text-4xl font-extrabold text-text-dark mb-6 leading-tight">{title}</h2>
            <p class="text-lg text-text-body mb-8 leading-[1.7]">{description}</p>

            <div class="flex flex-col gap-3 w-full">
                {accordions.map((acc, index) => (
                    <div class="bg-white border border-border-color rounded-xl overflow-hidden transition-all duration-200 hover:shadow-md hover:border-gray-300">
                        <details class="w-full group" open={index === 0}>
                            <summary class="flex items-center justify-between p-5 cursor-pointer text-[1.1rem] font-semibold text-text-dark list-none [&::-webkit-details-marker]:hidden">
                                <div class="flex items-center gap-4">
                                    {index === 0 && <svg class="text-primary w-[22px] h-[22px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><rect x="7" y="7" width="3" height="9"/><rect x="14" y="7" width="3" height="5"/></svg>}
                                    {index === 1 && <svg class="text-primary w-[22px] h-[22px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>}
                                    {acc.title}
                                </div>
                                <svg class="text-text-muted transition-transform duration-200 group-open:rotate-180" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                            </summary>
                            <div class="pl-[3.25rem] pr-5 pb-5 text-text-body text-[0.95rem] leading-[1.6]">
                                {acc.content}
                            </div>
                        </details>
                    </div>
                ))}
            </div>
        </div>

        <div class="w-full lg:w-1/2 bg-white border border-border-color rounded-[20px] h-[400px] shadow-md relative overflow-hidden flex items-center justify-center [background-image:radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:20px_20px]">
            <div class="w-[80%] h-[70%] bg-white border border-border-color rounded-xl shadow-lg flex flex-col">
                <div class="h-[30px] border-b border-border-color bg-bg-app flex items-center px-4 gap-1.5">
                    <div class="w-2 h-2 rounded-full bg-gray-300"></div><div class="w-2 h-2 rounded-full bg-gray-300"></div><div class="w-2 h-2 rounded-full bg-gray-300"></div>
                </div>
                <div class="flex-1 p-4 flex gap-2">
                    <div class="flex-1 bg-bg-app rounded-lg p-2 flex flex-col gap-2">
                        <div class="bg-gray-300 h-3 rounded w-[70%]"></div>
                        <div class="bg-white rounded-md p-5 border border-border-color shadow-sm"></div>
                        <div class="bg-white rounded-md p-5 border border-border-color shadow-sm"></div>
                    </div>
                    <div class="flex-1 bg-bg-app rounded-lg p-2 flex flex-col gap-2">
                        <div class="bg-gray-300 h-3 rounded w-[70%]"></div>
                        <div class="bg-white rounded-md p-5 border border-border-color shadow-sm"></div>
                    </div>
                    <div class="flex-1 bg-bg-app rounded-lg p-2 flex flex-col gap-2">
                        <div class="bg-gray-300 h-3 rounded w-[70%]"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
