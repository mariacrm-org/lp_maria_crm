---
// src/components/ComoFunciona.astro
interface Step {
  number: number;
  title: string;
  description: string;
}

interface Props {
  title: string;
  description: string;
  steps: Step[];
}

const { title, description, steps } = Astro.props;
---
<section id="como-funciona" class="w-full py-24 border-t border-border-color bg-white">
    <div class="max-w-[1440px] mx-auto px-6">
        <div class="text-center mb-16 max-w-[700px] mx-auto">
            <h2 class="text-4xl font-extrabold text-text-dark mb-4 tracking-tight">{title}</h2>
            <p class="text-lg text-text-body">{description}</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mt-14 relative">
            {steps.map((step) => (
                <div class="text-center p-8 bg-white border border-border-color rounded-2xl transition-all duration-200 hover:-translate-y-1 hover:shadow-md">
                    <div class="w-[52px] h-[52px] bg-primary text-white rounded-full font-display text-[1.4rem] font-extrabold flex items-center justify-center mx-auto mb-5">{step.number}</div>
                    <h3 class="text-lg font-bold text-text-dark mb-2.5">{step.title}</h3>
                    <p class="text-[0.92rem] text-text-muted leading-relaxed">{step.description}</p>
                </div>
            ))}
        </div>
    </div>
</section>
