---
// src/components/Footer.astro
interface Props {
  description: string;
  contactLabel: string;
  whatsappNumber: string;
  whatsappUrl: string;
  copyright: string;
}

const { description, contactLabel, whatsappNumber, whatsappUrl, copyright } = Astro.props;
---
<footer class="py-12 text-center text-text-muted text-[0.95rem] border-t border-border-color max-w-[1440px] mx-auto px-6">
    <p>{description}</p>
    <p class="mt-3 text-[0.85rem]">
        {contactLabel}
        <a href={whatsappUrl} target="_blank" class="text-primary no-underline font-semibold hover:underline">{whatsappNumber}</a>
    </p>
    <p class="mt-3 text-[0.82rem] text-gray-400">&copy; {new Date().getFullYear()} {copyright}</p>
</footer>
