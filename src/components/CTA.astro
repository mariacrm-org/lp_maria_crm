---
// src/components/CTA.astro
interface CtaItem {
  label: string;
  icon?: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  primaryCta: CtaItem;
  secondaryCta: CtaItem;
}

const { title, description, primaryCta, secondaryCta } = Astro.props;
---
<section class="text-center py-32 bg-primary bg-[linear-gradient(135deg,#8b2efc_0%,#6018c6_100%)] text-white max-w-[1440px] mx-auto px-6">
    <div>
        <h2 class="text-white text-4xl font-extrabold mb-4 tracking-tight">{title}</h2>
        <p class="text-white/90 text-[1.15rem] mb-10">{description}</p>
        <div class="flex gap-4 justify-center items-center flex-wrap">
            <a href={primaryCta.url} class="bg-white text-primary px-7 py-3 rounded-lg no-underline font-semibold text-[15px] inline-flex items-center gap-2 border-none cursor-pointer transition-all duration-200 hover:-translate-y-[2px]" id="cta-final-planos">
                {primaryCta.label}
            </a>
            <a href={secondaryCta.url} target="_blank" class="bg-transparent text-white border-2 border-white/50 px-7 py-3 rounded-lg no-underline font-semibold text-[15px] transition-all duration-200 inline-flex items-center justify-center gap-2 hover:bg-white/10 hover:border-white" id="cta-final-wpp">
                {secondaryCta.icon && (
                    <span class="material-symbols-outlined text-[1.2rem]">{secondaryCta.icon}</span>
                )}
                {secondaryCta.label}
            </a>
        </div>
    </div>
</section>
